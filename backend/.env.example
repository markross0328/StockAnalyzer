PORT=4000
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=1d

AWS_REGION=us-east-1
# Set for local DynamoDB usage only:
# DYNAMODB_ENDPOINT=http://localhost:8000

DYNAMODB_TABLE_USERS=stock-analyzer-users
DYNAMODB_TABLE_FAVORITES=stock-analyzer-favorites
DYNAMODB_TABLE_REVOKED_TOKENS=stock-analyzer-revoked-tokens

ALPHAVANTAGE_API_KEY=replace-with-alphavantage-key
STOCK_CACHE_TTL_MS=0
